<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nonograma #1 · Tranqui Puzzle Club</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&display=swap');

    :root {
      --background: #f5f0e7;
      --paper: #fffaf1;
      --text: #282522;
      --muted: #6f6962;
      --burgundy: #6d2015;
      --burgundy-dark: #4f160e;
      --mustard: #d9a441;
      --sage: #8f9d7d;
      --grid-light: #d8d1c6;
      --cell-size: clamp(21px, 4.1vw, 38px);
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      padding: 42px 16px;
      color: var(--text);
      background: var(--background);
      font-family: "DM Sans", Arial, sans-serif;
    }

    .page {
      width: min(1040px, 100%);
      margin: 0 auto;
    }

    .paper {
      padding: clamp(28px, 5vw, 58px);
      background: var(--paper);
      border: 1px solid var(--text);
      box-shadow: 10px 10px 0 var(--mustard);
    }

    .paper::before,
    .paper::after {
      display: none;
    }

    header {
      max-width: 700px;
      margin: 0 auto 34px;
      text-align: center;
    }

    .eyebrow {
      margin: 0 0 12px;
      color: var(--burgundy);
      font-family: "DM Sans", Arial, sans-serif;
      font-size: .76rem;
      font-weight: 700;
      letter-spacing: .17em;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      color: var(--text);
      font-family: "Fraunces", Georgia, serif;
      font-size: clamp(2.8rem, 7vw, 5.7rem);
      font-weight: 600;
      line-height: .95;
      letter-spacing: -.045em;
      text-transform: none;
      text-shadow: none;
    }

    .subtitle {
      max-width: 610px;
      margin: 18px auto 0;
      color: var(--muted);
      font-size: .98rem;
      line-height: 1.65;
    }

    .game-wrap {
      display: flex;
      justify-content: center;
      overflow-x: auto;
      padding: 8px 4px 20px;
    }

    .nonogram {
      display: grid;
      grid-template-columns: auto auto;
      grid-template-rows: auto auto;
      width: max-content;
      user-select: none;
      touch-action: manipulation;
    }

    .corner {
      grid-column: 1;
      grid-row: 1;
      min-width: calc(var(--cell-size) * 3.1);
      min-height: calc(var(--cell-size) * 3.1);
      border-right: 2px solid var(--burgundy);
      border-bottom: 2px solid var(--burgundy);
      background: var(--paper);
    }

    .column-clues {
      grid-column: 2;
      grid-row: 1;
      display: grid;
      border-bottom: 2px solid var(--burgundy);
    }

    .column-clue {
      width: var(--cell-size);
      min-height: calc(var(--cell-size) * 3.1);
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      align-items: center;
      gap: 1px;
      padding: 5px 0 7px;
      border-right: 1px solid var(--grid-light);
      color: var(--burgundy-dark);
      background: var(--paper);
      font-family: "Fraunces", Georgia, serif;
      font-size: clamp(.62rem, 1.7vw, .88rem);
      font-weight: 600;
    }

    .column-clue:nth-child(5n) {
      border-right: 2px solid var(--burgundy);
    }

    .row-clues {
      grid-column: 1;
      grid-row: 2;
      display: grid;
      border-right: 2px solid var(--burgundy);
    }

    .row-clue {
      min-width: calc(var(--cell-size) * 3.1);
      height: var(--cell-size);
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: .36em;
      padding: 0 8px;
      border-bottom: 1px solid var(--grid-light);
      color: var(--burgundy-dark);
      background: var(--paper);
      font-family: "Fraunces", Georgia, serif;
      font-size: clamp(.66rem, 1.8vw, .92rem);
      font-weight: 600;
    }

    .row-clue:nth-child(5n) {
      border-bottom: 2px solid var(--burgundy);
    }

    .grid {
      grid-column: 2;
      grid-row: 2;
      display: grid;
      background: var(--paper);
    }

    .cell {
      position: relative;
      width: var(--cell-size);
      height: var(--cell-size);
      padding: 0;
      border: 0;
      border-right: 1px solid var(--grid-light);
      border-bottom: 1px solid var(--grid-light);
      background: var(--paper);
      cursor: pointer;
      transition: background .12s ease;
    }

    .cell:hover {
      background: #eee6d8;
      z-index: 1;
    }

    .cell:focus-visible {
      outline: 3px solid var(--mustard);
      outline-offset: -3px;
      z-index: 2;
    }

    .cell.filled {
      background: var(--burgundy);
    }

    .cell.crossed::before,
    .cell.crossed::after {
      content: "";
      position: absolute;
      top: 50%;
      left: 18%;
      width: 64%;
      height: 2px;
      background: var(--burgundy);
      transform-origin: center;
    }

    .cell.crossed::before {
      transform: rotate(45deg);
    }

    .cell.crossed::after {
      transform: rotate(-45deg);
    }

    .cell:nth-child(5n) {
      border-right: 2px solid var(--burgundy);
    }

    .cell.major-row {
      border-bottom: 2px solid var(--burgundy);
    }

    .controls {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 12px;
      margin-top: 26px;
    }

    button.action {
      appearance: none;
      min-width: 168px;
      padding: 13px 18px;
      border: 1px solid var(--text);
      border-radius: 0;
      color: var(--paper);
      background: var(--burgundy);
      box-shadow: none;
      font-family: "DM Sans", Arial, sans-serif;
      font-size: .78rem;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
      cursor: pointer;
      transform: none;
      transition: transform .15s ease, background .15s ease;
    }

    button.action:nth-child(2) {
      color: var(--text);
      background: var(--mustard);
      transform: none;
    }

    button.action:hover {
      transform: translateY(-2px);
      background: var(--burgundy-dark);
    }

    button.action:nth-child(2):hover {
      background: #c89331;
    }

    button.action:active {
      transform: translateY(0);
      box-shadow: none;
    }

    .help {
      max-width: 650px;
      margin: 23px auto 0;
      color: var(--muted);
      font-size: .86rem;
      line-height: 1.65;
      text-align: center;
    }

    .solution-note {
      width: fit-content;
      max-width: 100%;
      margin: 34px auto 0;
      padding: 12px 18px;
      border: 1px solid var(--text);
      border-radius: 0;
      color: var(--text);
      background: var(--sage);
      font-family: "Fraunces", Georgia, serif;
      font-size: 1rem;
      font-weight: 600;
      font-style: italic;
      text-align: center;
      transform: none;
    }

    footer {
      margin-top: 28px;
      color: var(--muted);
      font-family: "DM Sans", Arial, sans-serif;
      font-size: .72rem;
      letter-spacing: .12em;
      text-align: center;
      text-transform: uppercase;
    }

    @media (max-width: 620px) {
      body {
        padding: 18px 8px;
      }

      .paper {
        padding: 30px 10px 34px;
        box-shadow: 6px 6px 0 var(--mustard);
      }

      .subtitle {
        padding: 0 12px;
      }

      .corner,
      .row-clue {
        min-width: calc(var(--cell-size) * 2.55);
      }

      .row-clue {
        padding: 0 5px;
        gap: .25em;
      }

      .column-clue {
        min-height: calc(var(--cell-size) * 2.8);
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="paper">
      <header>
        <p class="eyebrow">Tranqui Puzzle Club</p>
        <h1>Nonograma #1</h1>
        <p class="subtitle">
          Completá la grilla usando las pistas de cada fila y columna.
          No hace falta iniciar sesión y tu progreso queda guardado en este dispositivo.
        </p>
      </header>

      <div class="game-wrap">
        <div class="nonogram" id="nonogram" aria-label="Nonograma interactivo">
          <div class="corner" aria-hidden="true"></div>
          <div class="column-clues" id="columnClues"></div>
          <div class="row-clues" id="rowClues"></div>
          <div class="grid" id="grid"></div>
        </div>
      </div>

      <div class="controls">
        <button class="action" id="clearButton" type="button">Borrar todo</button>
        <button class="action" id="downloadButton" type="button">Descargar imagen</button>
      </div>

      <p class="help">
        Clic izquierdo: rellenar una casilla · Clic derecho: marcar una X.<br>
        En celular, tocá una vez para rellenar y mantené presionado para marcar una X.
      </p>

      <p class="solution-note">La solución estará disponible la semana que viene.</p>
    </section>

    <footer>Una nueva dosis de puzzles, cada semana.</footer>
  </main>

  <script>
    /*
      Este archivo contiene únicamente las pistas del nonograma.
      No incluye, comprueba ni revela la solución.
    */
    const rowNumbers = [
      [1, 1],
      [3, 3],
      [10],
      [12],
      [3, 2, 2],
      [3, 1, 2, 1, 2],
      [3, 2, 3],
      [4, 2, 2],
      [14],
      [7, 5],
      [10],
      [4],
      [3, 6],
      [1, 1, 6],
      [10]
    ];

    const columnNumbers = [
      [1, 1, 2],
      [7, 1],
      [9, 3],
      [11, 1],
      [3, 3, 1],
      [2, 1, 3, 3],
      [2, 7],
      [7, 5],
      [7, 5],
      [3, 7],
      [4, 1, 3, 3],
      [3, 3, 1],
      [8],
      [6],
      [1, 1]
    ];

    const rows = rowNumbers.length;
    const cols = columnNumbers.length;
    const storageKey = "tranqui-nonogram-1-progress";

    const grid = document.getElementById("grid");
    const rowClues = document.getElementById("rowClues");
    const columnClues = document.getElementById("columnClues");
    const clearButton = document.getElementById("clearButton");
    const downloadButton = document.getElementById("downloadButton");

    const state = Array.from({ length: rows }, () => Array(cols).fill(0));
    let longPressTimer = null;
    let longPressTriggered = false;


    function createClues() {
      rowClues.style.gridTemplateRows = `repeat(${rows}, var(--cell-size))`;
      columnClues.style.gridTemplateColumns = `repeat(${cols}, var(--cell-size))`;

      rowNumbers.forEach((numbers) => {
        const clue = document.createElement("div");
        clue.className = "row-clue";
        numbers.forEach(number => {
          const span = document.createElement("span");
          span.textContent = number;
          clue.appendChild(span);
        });
        rowClues.appendChild(clue);
      });

      columnNumbers.forEach((numbers) => {
        const clue = document.createElement("div");
        clue.className = "column-clue";
        numbers.forEach(number => {
          const span = document.createElement("span");
          span.textContent = number;
          clue.appendChild(span);
        });
        columnClues.appendChild(clue);
      });
    }

    function createGrid() {
      grid.style.gridTemplateColumns = `repeat(${cols}, var(--cell-size))`;
      grid.style.gridTemplateRows = `repeat(${rows}, var(--cell-size))`;

      for (let row = 0; row < rows; row++) {
        for (let col = 0; col < cols; col++) {
          const cell = document.createElement("button");
          cell.type = "button";
          cell.className = "cell";
          cell.dataset.row = row;
          cell.dataset.col = col;
          cell.setAttribute("aria-label", `Fila ${row + 1}, columna ${col + 1}`);

          if ((row + 1) % 5 === 0) cell.classList.add("major-row");

          cell.addEventListener("click", () => {
            if (longPressTriggered) {
              longPressTriggered = false;
              return;
            }
            toggleFilled(row, col);
          });

          cell.addEventListener("contextmenu", (event) => {
            event.preventDefault();
            toggleCross(row, col);
          });

          cell.addEventListener("pointerdown", (event) => {
            if (event.pointerType === "mouse") return;
            longPressTriggered = false;
            longPressTimer = window.setTimeout(() => {
              longPressTriggered = true;
              toggleCross(row, col);
            }, 500);
          });

          ["pointerup", "pointercancel", "pointerleave"].forEach(eventName => {
            cell.addEventListener(eventName, () => {
              if (longPressTimer) window.clearTimeout(longPressTimer);
            });
          });

          grid.appendChild(cell);
        }
      }
    }

    function toggleFilled(row, col) {
      state[row][col] = state[row][col] === 1 ? 0 : 1;
      renderCell(row, col);
      saveProgress();
    }

    function toggleCross(row, col) {
      state[row][col] = state[row][col] === 2 ? 0 : 2;
      renderCell(row, col);
      saveProgress();
    }

    function renderCell(row, col) {
      const index = row * cols + col;
      const cell = grid.children[index];
      cell.classList.toggle("filled", state[row][col] === 1);
      cell.classList.toggle("crossed", state[row][col] === 2);
      cell.setAttribute(
        "aria-pressed",
        state[row][col] === 1 ? "true" : "false"
      );
    }

    function saveProgress() {
      localStorage.setItem(storageKey, JSON.stringify(state));
    }

    function loadProgress() {
      try {
        const saved = JSON.parse(localStorage.getItem(storageKey));
        if (!Array.isArray(saved) || saved.length !== rows) return;

        saved.forEach((savedRow, row) => {
          if (!Array.isArray(savedRow) || savedRow.length !== cols) return;
          savedRow.forEach((value, col) => {
            state[row][col] = [0, 1, 2].includes(value) ? value : 0;
            renderCell(row, col);
          });
        });
      } catch {
        localStorage.removeItem(storageKey);
      }
    }

    clearButton.addEventListener("click", () => {
      const confirmed = window.confirm("¿Querés borrar todo el progreso del nonograma?");
      if (!confirmed) return;

      for (let row = 0; row < rows; row++) {
        for (let col = 0; col < cols; col++) {
          state[row][col] = 0;
          renderCell(row, col);
        }
      }

      localStorage.removeItem(storageKey);
    });

    downloadButton.addEventListener("click", () => {
      const cell = 42;
      const clueSpace = 150;
      const topSpace = 170;
      const margin = 60;
      const footerSpace = 110;
      const canvas = document.createElement("canvas");

      canvas.width = margin * 2 + clueSpace + cols * cell;
      canvas.height = margin * 2 + topSpace + rows * cell + footerSpace;

      const ctx = canvas.getContext("2d");
      ctx.fillStyle = "#f4ead6";
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      ctx.fillStyle = "#493f37";
      ctx.textAlign = "center";
      ctx.font = "700 38px Georgia";
      ctx.fillText("NONOGRAMA #1", canvas.width / 2, 54);

      ctx.fillStyle = "#7f493e";
      ctx.font = "700 15px Arial";
      ctx.fillText("TRANQUI PUZZLE CLUB", canvas.width / 2, 82);

      const originX = margin + clueSpace;
      const originY = margin + topSpace;

      ctx.font = "700 15px Arial";
      ctx.fillStyle = "#493f37";

      rowNumbers.forEach((numbers, row) => {
        ctx.textAlign = "right";
        ctx.textBaseline = "middle";
        ctx.fillText(
          numbers.join("   "),
          originX - 12,
          originY + row * cell + cell / 2
        );
      });

      columnNumbers.forEach((numbers, col) => {
        ctx.textAlign = "center";
        ctx.textBaseline = "bottom";
        numbers.forEach((number, index) => {
          const reverseIndex = numbers.length - 1 - index;
          ctx.fillText(
            number,
            originX + col * cell + cell / 2,
            originY - 10 - reverseIndex * 20
          );
        });
      });

      for (let row = 0; row < rows; row++) {
        for (let col = 0; col < cols; col++) {
          const x = originX + col * cell;
          const y = originY + row * cell;

          ctx.fillStyle = state[row][col] === 1 ? "#493f37" : "#f8f0df";
          ctx.fillRect(x, y, cell, cell);

          if (state[row][col] === 2) {
            ctx.strokeStyle = "#7f493e";
            ctx.lineWidth = 2.5;
            ctx.beginPath();
            ctx.moveTo(x + 10, y + 10);
            ctx.lineTo(x + cell - 10, y + cell - 10);
            ctx.moveTo(x + cell - 10, y + 10);
            ctx.lineTo(x + 10, y + cell - 10);
            ctx.stroke();
          }

          ctx.strokeStyle = "#65584d";
          ctx.lineWidth = ((col + 1) % 5 === 0 || (row + 1) % 5 === 0) ? 2.5 : 1;
          ctx.strokeRect(x, y, cell, cell);
        }
      }

      ctx.fillStyle = "#7f493e";
      ctx.textAlign = "center";
      ctx.textBaseline = "alphabetic";
      ctx.font = "700 17px Georgia";
      ctx.fillText(
        "La solución estará disponible la semana que viene.",
        canvas.width / 2,
        canvas.height - 42
      );

      const link = document.createElement("a");
      link.download = "tranqui-nonograma-1.png";
      link.href = canvas.toDataURL("image/png");
      link.click();
    });

    createClues();
    createGrid();
    loadProgress();
  </script>
</body>
</html>
